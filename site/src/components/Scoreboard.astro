---
import '../styles/scoreboard.css';
import EpisodeLinks from './EpisodeLinks.astro';
import MovieCard from './MovieCard.astro';
import PageHero from './PageHero.astro';
import RulesPanel from './RulesPanel.astro';
import ScoreSummary from './ScoreSummary.astro';
import ScoreTable from './ScoreTable.astro';
import SeasonSwitcher from './SeasonSwitcher.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import type { GameData } from '../data/games';
import { advantage as advantageOf, fmtDate } from '../lib/format';

interface Props {
  game: GameData;
  allGames: GameData[];
}

const { game, allGames } = Astro.props;
const { meta, movies, totals } = game;

const base = import.meta.env.BASE_URL;
function path(p: string): string {
  return `${base}/${p}`.replace(/\/{2,}/g, '/');
}

const lowerWins = meta.scoring.objective === 'low';
const overallAdvantage = advantageOf(totals.sean, totals.amanda, lowerWins);
const leader = overallAdvantage === 0 ? null : overallAdvantage > 0 ? 'sean' : 'amanda';

// The event title already carries the season (e.g. "Summer Movie Preview"), so
// the year alone distinguishes editions without repeating the season.
const pageTitle = `The Big Picture · ${meta.title} ${meta.year} Scoreboard`;
const description = `Sean vs. Amanda: tracking box office and Metacritic predictions from The Big Picture's ${meta.title} ${meta.year}.`;

// Compact payload for the hover/click cards.
const cardData = Object.fromEntries(
  movies
    .filter((movie) => movie.tmdb)
    .map((movie) => [
      movie.title,
      {
        poster: movie.tmdb!.poster_url,
        date: movie.releaseDate
          ? `${fmtDate(movie.releaseDate)}, ${movie.releaseDate.slice(0, 4)}`
          : 'Release date TBD',
        runtime: movie.tmdb!.runtime,
        genres: movie.tmdb!.genres,
        tagline: movie.tmdb!.tagline,
        overview: movie.tmdb!.overview,
        directors: movie.tmdb!.directors,
        cast: movie.tmdb!.cast,
        links: movie.links,
      },
    ]),
);
---

<BaseLayout title={pageTitle} description={description} bodyCelebrate={!meta.live && leader !== null}>
  <PageHero meta={meta} />

  <div class="filmstrip" aria-hidden="true"></div>

  <main>
    <SeasonSwitcher games={allGames} currentId={meta.id} />
    <ScoreSummary game={game} leader={leader} />
    <EpisodeLinks episodes={meta.episodes} />
    <RulesPanel scoring={meta.scoring} />
    <ScoreTable game={game} />
  </main>

  <div class="filmstrip" aria-hidden="true"></div>

  <footer>
    <p class="meta-link">
      <a href={path('colophon')}>Colophon &amp; credits</a>
    </p>
  </footer>

  <MovieCard cardData={cardData} />

  <script>
    import '../scripts/scoreboard.ts';
    import '../scripts/confetti.ts';
  </script>
</BaseLayout>
